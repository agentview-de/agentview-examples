<Window x:Class="AgentView.TokenCounter.Views.ApiKeyLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign in with an API key"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        Background="{StaticResource Brush.Background}"
        FontFamily="{StaticResource Font.Sans}"
        TextElement.Foreground="{StaticResource Brush.TextPrimary}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Grid Margin="28,24,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  title -->
            <RowDefinition Height="Auto"/>  <!-- 1  intro -->
            <RowDefinition Height="Auto"/>  <!-- 2  instructions card -->
            <RowDefinition Height="Auto"/>  <!-- 3  fields -->
            <RowDefinition Height="Auto"/>  <!-- 4  error -->
            <RowDefinition Height="Auto"/>  <!-- 5  buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Style="{StaticResource Text.Title}"
                   Margin="0,0,0,6"
                   Text="Sign in with an API key"/>

        <TextBlock Grid.Row="1"
                   Style="{StaticResource Text.Caption}"
                   Margin="0,0,0,18"
                   TextWrapping="Wrap"
                   Text="If you'd rather mint a key in the agentView dashboard yourself instead of letting the wizard control a browser session, paste it here. The bridge will only push data to the slot you specify — it will not create displays, send HTML or mint new keys on your behalf."/>

        <!-- ── How-to card ──────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource Brush.SurfaceMuted}"
                CornerRadius="{StaticResource Radius.M}"
                Padding="16,14,16,14"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock FontSize="{StaticResource FontSize.Body}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0,0,0,6"
                           Text="How to mint a key in the dashboard"/>

                <TextBlock Margin="0,0,0,2"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="{StaticResource FontSize.Body}"
                           TextWrapping="Wrap">
                    <Run Text="1." FontWeight="SemiBold"/>
                    <Run Text=" Open "/>
                    <Hyperlink x:Name="DashboardLink"
                               NavigateUri="https://agentview.de/dashboard.html#/settings/api-keys"
                               RequestNavigate="OnLinkRequestNavigate">agentview.de</Hyperlink>
                    <Run Text=" → "/>
                    <Run Text="Settings → API Keys → + Create New Key" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text="."/>
                </TextBlock>
                <TextBlock Margin="0,4,0,2"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="{StaticResource FontSize.Body}"
                           TextWrapping="Wrap">
                    <Run Text="2." FontWeight="SemiBold"/>
                    <Run Text=" Name it e.g. "/>
                    <Run Text="Token Counter" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text=", scope "/>
                    <Run Text="content_only" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text=", permission "/>
                    <Run Text="write" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text=", capability "/>
                    <Run Text="slot.write" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text=", allowed slot slug "/>
                    <Run Text="claude-usage" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text="."/>
                </TextBlock>
                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="{StaticResource FontSize.Body}"
                           TextWrapping="Wrap">
                    <Run Text="3." FontWeight="SemiBold"/>
                    <Run Text=" Copy the "/>
                    <Run Text="avk_…" FontFamily="Consolas, Menlo, monospace"/>
                    <Run Text=" string the dashboard shows once and paste it below."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ── Form fields ──────────────────────────────────────── -->
        <StackPanel Grid.Row="3">

            <TextBlock Style="{StaticResource Text.Label}"
                       Margin="0,0,0,4" Text="API key"/>
            <PasswordBox x:Name="ApiKeyBox"
                         FontFamily="Consolas, Menlo, monospace"
                         PasswordChanged="OnFieldChanged"/>
            <TextBlock Style="{StaticResource Text.Caption}"
                       Margin="0,4,0,14"
                       Text="DPAPI-protected on disk after save."/>

            <!-- ── Mode choice ──────────────────────────────────
                 Determines how much of the wizard the key has to
                 cover. Full setup = key with display.* capabilities;
                 the bridge handles display creation + HTML push +
                 pair-by-code. Slot-only = lighter key, the operator
                 sets up the display themselves in the dashboard. -->
            <TextBlock Style="{StaticResource Text.Label}"
                       Margin="0,0,0,6" Text="What can this key do?"/>
            <RadioButton x:Name="ModeFull"
                         GroupName="ApiKeyMode"
                         IsChecked="True"
                         Margin="0,2,0,2"
                         Padding="6,1,0,1">
                <RadioButton.Content>
                    <StackPanel>
                        <TextBlock Text="Full setup (recommended)"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,1,0,0"
                                   Text="The bridge can create / pick displays, send the HTML and pair physical screens — same flow as the interactive login. Needs slot.write + display.read + display.send + display.manage capabilities."/>
                    </StackPanel>
                </RadioButton.Content>
            </RadioButton>
            <RadioButton x:Name="ModeSlotOnly"
                         GroupName="ApiKeyMode"
                         Margin="0,8,0,2"
                         Padding="6,1,0,1">
                <RadioButton.Content>
                    <StackPanel>
                        <TextBlock Text="Slot write only"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Style="{StaticResource Text.Caption}"
                                   TextWrapping="Wrap"
                                   Margin="0,1,0,0"
                                   Text="The bridge only writes to the slot below. You set up the display + HTML manually in the agentView dashboard. Needs only slot.write capability."/>
                    </StackPanel>
                </RadioButton.Content>
            </RadioButton>
            <Border Height="14"/>

            <TextBlock Style="{StaticResource Text.Label}"
                       Margin="0,0,0,4" Text="Data slot slug"/>
            <!-- Default value set in code-behind AFTER InitializeComponent.
                 If we set Text="claude-usage" inline, the XAML parser
                 raises TextChanged before the rest of the form fields
                 exist — OnFieldChanged then NRE's on SaveButton. -->
            <TextBox x:Name="SlugBox"
                     FontFamily="Consolas, Menlo, monospace"
                     TextChanged="OnFieldChanged"/>
            <TextBlock Style="{StaticResource Text.Caption}"
                       Margin="0,4,0,14"
                       Text="The slot the bridge writes into. Must match the slot your display reads."/>

            <TextBlock Style="{StaticResource Text.Label}"
                       Margin="0,0,0,4" Text="Group (optional)"/>
            <TextBox x:Name="GroupBox"
                     FontFamily="Consolas, Menlo, monospace"
                     TextChanged="OnFieldChanged"/>
            <TextBlock Style="{StaticResource Text.Caption}"
                       Margin="0,4,0,14"
                       Text="Blank = personal scope. Set when the slot is owned by a group."/>

        </StackPanel>

        <!-- ── Inline error (collapsed unless we have one) ──────── -->
        <TextBlock x:Name="ErrorText"
                   Grid.Row="4"
                   Foreground="{StaticResource Brush.Danger}"
                   FontSize="{StaticResource FontSize.Body}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Visibility="Collapsed"/>

        <!-- ── Buttons ──────────────────────────────────────────── -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Style="{StaticResource Button.Ghost}"
                    Content="Cancel"
                    Margin="0,0,8,0"
                    Click="OnCancelClicked"/>
            <Button x:Name="SaveButton"
                    Style="{StaticResource Button.Primary}"
                    Content="Use this API key"
                    IsEnabled="False"
                    Click="OnSaveClicked"/>
        </StackPanel>
    </Grid>
</Window>
