<Window x:Class="AgentView.TokenCounter.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Token Counter — Sign in"
        Width="900" Height="660"
        MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{StaticResource Brush.Background}"
        FontFamily="{StaticResource Font.Sans}"
        TextElement.Foreground="{StaticResource Brush.TextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="20,14,20,12">
            <StackPanel>
                <TextBlock x:Name="HeaderTitle"
                           Style="{StaticResource Text.Section}"
                           Text="Sign in"/>
                <TextBlock x:Name="HeaderSubtitle"
                           Style="{StaticResource Text.Caption}"
                           Margin="0,2,0,0"
                           Text="This window closes automatically once you are signed in."/>
            </StackPanel>
        </Border>

        <!-- ── WebView host (filled at runtime) ───────────────────────── -->
        <Border Grid.Row="1"
                x:Name="WebViewHost"
                Background="{StaticResource Brush.Surface}"
                Margin="14,0,14,12"
                CornerRadius="{StaticResource Radius.M}"
                ClipToBounds="True"/>

        <!-- ── Footer ───────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource Brush.Divider}"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Style="{StaticResource Text.Caption}"
                           Text="Session stays in the app's profile (%APPDATA%\agentView-token-counter\WebView2)."/>
                <Button   Grid.Column="1"
                          x:Name="CancelButton"
                          Style="{StaticResource Button.Ghost}"
                          Content="Cancel"
                          Click="OnCancelClicked"/>
            </Grid>
        </Border>
    </Grid>
</Window>
