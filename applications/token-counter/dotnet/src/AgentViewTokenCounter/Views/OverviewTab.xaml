<UserControl x:Class="AgentView.TokenCounter.Views.OverviewTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AgentView.TokenCounter.ViewModels"
             xmlns:conv="clr-namespace:AgentView.TokenCounter.Converters"
             Background="{StaticResource Brush.Background}"
             FontFamily="{StaticResource Font.Sans}"
             TextElement.Foreground="{StaticResource Brush.TextPrimary}"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType">

    <UserControl.Resources>

        <!-- Value converters -->
        <conv:SeverityBrushConverter  x:Key="SeverityBrush"/>
        <conv:NumberInkBrushConverter x:Key="NumberInkBrush"/>

        <!--
        ══════════════════════════════════════════════════════════════
          FEATURED card DataTemplate
          (2-column: title + big % left, bar + KV row right)
        ══════════════════════════════════════════════════════════════
          The big number stays in primary ink. Severity is communicated
          only through the bar — the "confident neutral type" move from
          Linear / Stripe where colour is reserved for the gauge.
          Run-based inline composition gives baseline-aligned NN% so
          the small "%" glyph sits on the typographic baseline of the
          large digit.
        -->
        <DataTemplate x:Key="FeaturedCardTemplate"
                      DataType="{x:Type vm:BucketRowViewModel}">
            <Border Style="{StaticResource Card}" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0 col 0: title + subtitle -->
                    <StackPanel Grid.Row="0" Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Label}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Text="Current rolling window"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Row 0 col 2: severity bar.
                         ProgressBar.Value (RangeBase) binds TwoWay by
                         default; the VM property is get-only, so an
                         implicit TwoWay binding throws on every render.
                         The view-model is display-only — bind OneWay. -->
                    <ProgressBar Grid.Row="0" Grid.Column="2"
                                 Value="{Binding UsedPct, Mode=OneWay}"
                                 Foreground="{Binding UsedPct, Mode=OneWay,
                                     Converter={StaticResource SeverityBrush}}"
                                 Background="{StaticResource Brush.Divider}"
                                 Height="6"
                                 VerticalAlignment="Center"/>

                    <!-- Row 2 col 0: big % + caption -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock
                            Foreground="{Binding UsedPct,
                                Converter={StaticResource NumberInkBrush}}"
                            FontFamily="{StaticResource Font.Sans}"
                            LineHeight="60">
                            <Run Text="{Binding UsedPct, Mode=OneWay}"
                                 FontSize="56" FontWeight="SemiBold"/>
                            <Run Text="%"
                                 FontSize="22" FontWeight="SemiBold"
                                 Foreground="{StaticResource Brush.TextSecondary}"
                                 BaselineAlignment="Baseline"/>
                        </TextBlock>
                        <TextBlock Text="{Binding OfLabel}"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Row 2 col 2: KV row (RESETS IN / USED / REMAINING) -->
                    <Grid Grid.Row="2" Grid.Column="2"
                          VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="RESETS IN"   Style="{StaticResource KvKey}"/>
                            <TextBlock Text="{Binding ResetsInShort}"
                                       Style="{StaticResource KvValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="USED"        Style="{StaticResource KvKey}"/>
                            <TextBlock Text="{Binding UsedPctLabel}"
                                       Style="{StaticResource KvValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="REMAINING"   Style="{StaticResource KvKey}"/>
                            <TextBlock Text="{Binding RemainingPct}"
                                       Style="{StaticResource KvValue}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!--
        ══════════════════════════════════════════════════════════════
          SECONDARY card DataTemplate
          (single-percentage + bar + reset caption, right column)
        ══════════════════════════════════════════════════════════════
        -->
        <DataTemplate x:Key="SecondaryCardTemplate"
                      DataType="{x:Type vm:BucketRowViewModel}">
            <Border Style="{StaticResource Card}" Padding="22">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>
                    <TextBlock
                        Foreground="{Binding UsedPct,
                            Converter={StaticResource NumberInkBrush}}"
                        FontFamily="{StaticResource Font.Sans}"
                        HorizontalAlignment="Right"
                        LineHeight="38"
                        Margin="0,14,0,12">
                        <Run Text="{Binding UsedPct, Mode=OneWay}"
                             FontSize="34" FontWeight="SemiBold"/>
                        <Run Text="%"
                             FontSize="16" FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.TextSecondary}"
                             BaselineAlignment="Baseline"/>
                    </TextBlock>
                    <ProgressBar Value="{Binding UsedPct, Mode=OneWay}"
                                 Foreground="{Binding UsedPct, Mode=OneWay,
                                     Converter={StaticResource SeverityBrush}}"
                                 Background="{StaticResource Brush.Divider}"
                                 Height="6" Margin="0,0,0,14"/>
                    <TextBlock Text="{Binding ResetCaption}"
                               Style="{StaticResource Text.Caption}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!--
        ══════════════════════════════════════════════════════════════
          SMALL card DataTemplate
          (one-third width, row 2 small-bucket cards)
        ══════════════════════════════════════════════════════════════
        -->
        <DataTemplate x:Key="SmallCardTemplate"
                      DataType="{x:Type vm:BucketRowViewModel}">
            <Border Style="{StaticResource Card}" Padding="20,18,20,18">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>
                    <TextBlock
                        Foreground="{Binding UsedPct,
                            Converter={StaticResource NumberInkBrush}}"
                        FontFamily="{StaticResource Font.Sans}"
                        HorizontalAlignment="Right"
                        LineHeight="26"
                        Margin="0,10,0,10">
                        <Run Text="{Binding UsedPct, Mode=OneWay}"
                             FontSize="22" FontWeight="SemiBold"/>
                        <Run Text="%"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.TextSecondary}"
                             BaselineAlignment="Baseline"/>
                    </TextBlock>
                    <ProgressBar Value="{Binding UsedPct, Mode=OneWay}"
                                 Foreground="{Binding UsedPct, Mode=OneWay,
                                     Converter={StaticResource SeverityBrush}}"
                                 Background="{StaticResource Brush.Divider}"
                                 Height="6" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ResetCaption}"
                               Style="{StaticResource Text.Caption}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <!-- ScrollBarVisibility="Auto" — only appears when the user shrinks
         the window below the design's natural content height. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20,16,20,20">
        <StackPanel>

            <!-- ── Sync strip ────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Padding="18,14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusBullet" Style="{StaticResource StatusBullet.Pending}"/>
                            <TextBlock x:Name="StatusHeadline"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSize.Section}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       Text="Waiting for first sync…"/>
                        </StackPanel>
                        <TextBlock x:Name="DisplayLine"
                                   Style="{StaticResource Text.Caption}"
                                   Margin="14,4,0,0"
                                   Text="No display configured yet"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SyncButton"
                                Style="{StaticResource Button.Primary}"
                                Content="Sync now"
                                Click="OnSyncClicked"/>
                        <Button x:Name="PauseButton"
                                Style="{StaticResource Button.Ghost}"
                                Content="Pause"
                                Margin="8,0,0,0"
                                Click="OnPauseClicked"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Empty state ───────────────────────────────────── -->
            <Border x:Name="EmptyCard"
                    Style="{StaticResource Card}"
                    Padding="24"
                    Visibility="Collapsed">
                <TextBlock Style="{StaticResource Text.Caption}"
                           TextAlignment="Center"
                           Text="No data yet. The next sync will populate this view."/>
            </Border>

            <!--
            ── Bucket grid ──────────────────────────────────────────
            3-column / 2-row layout from the designer mock:

              Row 0: Featured 5h (cols 0+1, 2*) + Weekly·all-models (col 2, 1*)
              Row 2: Three small cards, one-third each

            ContentControl slots receive DataTemplate-bound view-models
            set in code-behind (OverviewTab.xaml.cs). Using
            ContentControl.ContentTemplate pulls the right DataTemplate
            from the UserControl.Resources dictionary above — idiomatic
            WPF data binding, no BuildFeaturedCard() "build UI in C#"
            pattern.
            -->
            <Grid x:Name="BucketGrid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0 col 0: featured card -->
                <ContentControl x:Name="FeaturedHost"
                                Grid.Row="0" Grid.Column="0"
                                ContentTemplate="{StaticResource FeaturedCardTemplate}"/>

                <!-- Row 0 col 2: secondary card -->
                <ContentControl x:Name="SecondaryHost"
                                Grid.Row="0" Grid.Column="2"
                                ContentTemplate="{StaticResource SecondaryCardTemplate}"/>

                <!-- Row 2: three small cards -->
                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ContentControl x:Name="SmallHost0" Grid.Column="0"
                                    ContentTemplate="{StaticResource SmallCardTemplate}"/>
                    <ContentControl x:Name="SmallHost1" Grid.Column="2"
                                    ContentTemplate="{StaticResource SmallCardTemplate}"/>
                    <ContentControl x:Name="SmallHost2" Grid.Column="4"
                                    ContentTemplate="{StaticResource SmallCardTemplate}"/>
                </Grid>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
